{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ApiDocumentation": {
    "Enabled": false
  },
  "Database": {
    "RunMigrationsOnStartup": true
  },
  "Seed": {
    "CbhpmOnStartup": false,
    "UsersOnStartup": false
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "JwtSettings": {
    "SecretKey": "",
    "Issuer": "HemodinksAPI",
    "Audience": "HemodinksAPI",
    "ExpirationMinutes": 60
  },
  "Licensing": {
    "TrialDays": 14
  },
  "PasswordReset": {
    "UseEmail": false,
    "ExposeTokenInResponse": false
  },
  "Email": {
    "Provider": "",
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "",
      "Password": "",
      "EnableSsl": true,
      "TimeoutSeconds": 10
    },
    "FromEmail": "",
    "FromName": "Hemodinks"
  },
  "Frontend": {
    "ResetPasswordUrl": ""
  },
  "AzureStorage": {
    "ConnectionString": "",
    "ContainerName": "profile-photos",
    "PublicBaseUrl": "",
    "MaxBytes": 1048576
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/hemodinks-api-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ]
  }
}
