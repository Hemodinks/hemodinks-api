{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ApiDocumentation": {
    "Enabled": true
  },
  "Database": {
    "RunMigrationsOnStartup": true
  },
  "Seed": {
    "CbhpmOnStartup": true,
    "UsersOnStartup": true
  },
  "PasswordReset": {
    "UseEmail": true,
    "ExposeTokenInResponse": true
  }
}
